  m_text: "\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<b>Producer</b>\r\nKostas
    Dokos\r\n\r\n<b>Art Director</b>\r\nAdam Barton\r\n\r\n<b>Game Design Lead</b>\r\nEoin
    Matthews\r\n\r\n<b>Narrative Design Lead</b>\r\nBen Hendry\r\n\r\n<b>Level Design
    Lead</b>\r\nDavid Ling\r\nJamie Harris\r\n\r\n<b>User Experience Lead </b>\r\nLaura
    Eszter Kovacs\r\n\r\n<b>Sound Lead</b>\r\nKieran Moore\r\nFilip Jozic\r\n\r\n<b>Programming
    Lead</b>\r\nSarah Butlin\r\n\r\n<b>Art Leads</b>\r\nBrendon Smith\r\nDominika
    Kucharska\r\nLuke Jarman\r\n\r\n<b>Game Designers</b>\r\nBogdan Barbu\r\nJulio
    Arias\r\nMatej Gajdos\r\n\r\n<b>Narrative Designer</b>\r\nAtanas Pilev\r\nOliver
    Allison\r\n\r\n<b>Level Designers</b>\r\nAshley Mortlock\r\nHaydon Williams\r\nMacorley
    Hepden-Barker\r\nRafael Theodorou\r\nWilliam Hook\r\nWilliam Whitlam\r\n\r\n<b>User
    Experience Designers</b>\r\nAlexander Jones\r\nAlexander Slous\r\nMatthew Muhle\r\nNicholas
    Rawle\r\nRonnie Allum\r\n\r\n<b>Sound Designers</b>\r\nBradley Skelton\r\nCassie
    Hobbs\r\nSofia Denchovska\r\nTyler Denman\r\n\r\n<b>Programmers</b>\r\nBruno
    Cerqueria\r\nCameron Chester\r\nConnor Regan\r\nIzaak Lewis\r\nLucas Mellor\r\n\r\n<b>Artists</b>\r\nAndre
    Gomes\r\nAshley Simpkin\r\nCharlie Allen\r\nChristiano Miola\r\nEmma Summers\r\nErik
    Alve Buddha Svallfors\r\nErik Lennart Jarhult Viking\r\nIsaac Ellis-Bray\r\nKlaudia
    Mezynska\r\nLuke Goodenough\r\nNikolett Philippovits\r\nOwen West\r\nReiss Merrick\r\nToma
    Bieliauskaite\r\nWilliam Poy\r\n\r\n\r\n<b>External Credits</b>\r\n\r\n<b>Art</b>\r\nLumo-Art
    3D \u2013 Free Casual Food Pack \u2013 Mobile/VR \r\nDevDen \u2013 French Fries
